<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="payment_voucher_report_wizard" model="ir.ui.view">
        <field name="name">Payment.Voucher.Report.Wizard</field>
        <field name="model">payment.report</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="customer" options="{'no_create':True, 'no_create_edit':True}"/>
                    </group>
                    <group>
                        <field name="payment_ref" widget="many2many_tags" options="{'no_create':True, 'no_create_edit':True}"/>
                    </group>
                </group>
                <group>
                    <group>
                        <field name="from_date"/>
                    </group>
                    <group>
                        <field name="to_date"/>
                    </group>
                </group>
                <footer>
                    <button name="get_payment_voucher" type="object" string="Print" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_payment_voucher_report_wizard" model="ir.actions.act_window">
        <field name="name">Payment Voucher Report Wizard</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">payment.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_payment_voucher_report_wizard"
              name="Payment Report"
              sequence="600"
              parent="account.menu_finance_reports"
              action="action_payment_voucher_report_wizard"/>

</odoo>