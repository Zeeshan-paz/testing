<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="payment_voucher_report_action" model="ir.actions.report">
        <field name="name">Payment Voucher Report</field>
        <field name="model">payment.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bulk_payment.payment_voucher_report_template</field>
        <field name="report_file">bulk_payment.payment_voucher_report_template</field>
        <field name="binding_model_id" ref="model_payment_report"/>
        <field name="binding_type">report</field>
    </record>

    <record id="journal_entry_payment_voucher_report_action" model="ir.actions.report">
        <field name="name">Payment Voucher</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bulk_payment.journal_entry_payment_voucher</field>
        <field name="report_file">bulk_payment.journal_entry_payment_voucher</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="payment_voucher_report_template">
        <t t-call="web.html_container">
            <t t-set="o" t-value="doc"/>
            <t t-call="bulk_payment.payment_voucher_report_template"/>
        </t>
    </template>
</odoo>