<odoo>
    <template id="payment_voucher_report_template">
        <main>
            <div class="header" style="font-family: Lato; color: #495057;">

                <!-- Title -->
                <div style="text-align: left;">
                    <h4 style="margin: 0; font-size: 15px;">
                        <b>Agar Inernational Pvt Ltd</b>
                    </h4>
                </div>
                <div style="text-align: left; ">
                    <h4 style="margin: 0; font-size: 15px;">
                        <b>Pakistan</b>
                    </h4>
                </div>
                <div style="border-bottom: 1px solid grey; margin-top: 10px;"></div>
            </div>

            <div class="article o_report_layout_standard"
                 style="position: relative; background-image: url('/bulk_payment/static/img/background_image.jpg'); background-size: cover; background-position: bottom center; background-repeat: no-repeat; font-family: Lato; color: #495057;">
                <div style="text-align: center; margin-bottom: 15px;">
                    <h2 style="margin: 0; font-size: 28px;">
                        <b>Payment Voucher</b>
                    </h2>
                </div>
                <!-- Top Row: Left + Right -->
                <div class="row" style="display: flex; justify-content: space-between; align-items: flex-start;">

                    <!-- LEFT SIDE -->
                    <div class="col-6" style="width: 60%;">

                        <div style="margin-bottom: 5px;">
                            <b>Partner:</b>
                            <t t-esc="customer"/>
                        </div>

                        <div style="margin-bottom: 5px;">
                            <b>Date:</b>
                            <t t-esc="bill_date"/>
                        </div>

                        <div style="margin-bottom: 5px;">
                            <b>Payment Amount:</b>
                            <t t-esc="'{:,.2f}'.format(total_amount)"/>
                        </div>

                    </div>

                    <!-- RIGHT SIDE -->
                    <div class="col-4" style="width: 40%; text-align: right;">

                        <div style="margin-bottom: 5px;">
                            <b>From:</b>
                            <t t-esc="from"/>
                        </div>

                        <div style="margin-bottom: 5px;">
                            <b>To:</b>
                            <t t-esc="to"/>
                        </div>

                    </div>

                </div>
                <br/>
                <table class="table table-bordered" style="width: 100%; border: 2px solid black;">
                    <thead style="border-bottom: 1px;">
                        <tr>
                            <th style="font-size: 15px; vertical-align: middle;">Payment Number</th>
                            <th style="font-size: 15px; vertical-align: middle;">Payment Date</th>
                            <th style="font-size: 15px; vertical-align: middle;">Partner</th>
                            <th style="font-size: 15px; vertical-align: middle;">Journal</th>
                            <!-- <th style="font-size: 15px; vertical-align: middle;">Payment method</th>-->
                            <!-- <th style="font-size: 15px; vertical-align: middle;">Amount in words</th>-->
                            <th style="font-size: 15px; vertical-align: middle;">Check No.</th>
                            <th style="font-size: 15px; vertical-align: middle;">Description</th>
                            <th style="font-size: 15px; vertical-align: middle;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="delivery_data" t-as="d">
                            <tr>
                                <td style="font-size: 13px; vertical-align: middle;">
                                    <t t-esc="d['name']"/>
                                </td>
                                <td style="font-size: 13px; vertical-align: middle;">
                                    <t t-esc="d['date']"/>
                                </td>
                                <td style="font-size: 13px; vertical-align: middle;">
                                    <t t-esc="d['partner']"/>
                                </td>
                                <td style="font-size: 13px; vertical-align: middle;">
                                    <t t-esc="d['journal']"/>
                                </td>
                                <td style="font-size: 13px; vertical-align: middle;">
                                        <t t-esc="d.get('cheque_no', '')"/>
                                </td>
                                <td style="font-size: 13px; vertical-align: middle;">
                                    <t t-esc="d['description']"/>
                                </td>
                                <td style="font-size: 13px; vertical-align: middle;">
                                    <t t-esc="'{:,.2f}'.format(d['amount'])"/>
                                </td>
                            </tr>
                        </t>
                        <tr>
                            <td colspan="6" class="text-left">
                                <strong>Total</strong>
                            </td>
                            <td class="text-end">
                                <strong>
                                    <t t-esc="'{:,.2f}'.format(sum(line['amount'] for line in delivery_data))"/>
                                </strong>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div class="row">
                    <div class="col-12">
                        <table class="table table-bordered" style="width: 100%; border: 2px solid black;">
                            <tbody>
                                <tr class="text-start">
                                    <th>Amount in words:</th>
                                </tr>
                                <tr>
                                    <td>
                                        <t t-esc="amount_in_words"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="footer" style="font-size:11pt; text-align:center; width:100%;">
                    <div style="left: 0; width: 100%;">

                        <div style="display: flex; justify-content: space-between; font-size: 15px;">

                            <div class="row" style="width:995px;">
                                <div class="col-3 text-start">
                                    <p class="text-start">
                                        Prepared By:
                                        <small class="text-muted">________________</small>
                                    </p>
                                </div>

                                <div class="col-3 text-start">
                                    <p class="text-start">
                                        Checked By:
                                        <small class="text-muted">________________</small>
                                    </p>
                                </div>

                                <div class="col-3 text-start">
                                    <p class="text-start">
                                        Approoved By:
                                        <small class="text-muted">________________</small>
                                    </p>
                                </div>

                                <div class="col-3 text-start">
                                    <p class="text-start">
                                        Posted By:
                                        <small class="text-muted">________________</small>
                                    </p>
                                </div>

                                <div class="col-3 text-start">
                                    <p class="text-start">
                                        Received By:
                                        <small class="text-muted">________________</small>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <br/>
                    <br/>
                    <div style="border-bottom: 2px solid black; margin-top: 10px;"></div>
                    <br/>
                    92-21-32415412-13-14, 92-21-32414711 info@agar.pk http://www.agar.pk<br/>
                    <div style="border-bottom: 2px solid black; margin-top: 10px;"></div>
                    Page <span class="page"/> of <span class="topage"/>
                </div>
            </div>
        </main>
    </template>
</odoo>